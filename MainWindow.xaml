<Window x:Class="SSHProfileLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SSH Profile Launcher" Height="560" Width="900"
        Icon="/Assets/app.ico"
        WindowStartupLocation="CenterScreen" FontSize="13">
    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="8,6">
                <Button x:Name="NewBtn" Content="{DynamicResource Btn_New}" Click="New_Click" Padding="12,4" Margin="0,0,6,0"/>
                <Button Content="{DynamicResource Btn_Edit}" Click="Edit_Click" Padding="12,4" Margin="0,0,6,0"/>
                <Button Content="{DynamicResource Btn_Delete}" Click="Delete_Click" Padding="12,4" Margin="0,0,6,0"/>
                <Separator Margin="6,2" Width="1"/>
                <Button Content="{DynamicResource Btn_Connect}" Click="Connect_Click" Padding="12,4" Margin="0,0,6,0" FontWeight="SemiBold"/>
                <Button Content="{DynamicResource Btn_OpenInBitvise}" Click="OpenInBitvise_Click" Padding="12,4" Margin="0,0,6,0"/>
                <Separator Margin="6,2" Width="1"/>
                <TextBlock Text="{DynamicResource Lbl_Search}" VerticalAlignment="Center" Margin="4,0,4,0"/>
                <TextBox x:Name="SearchBox" Width="180" Padding="3" VerticalAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>
                <Button Content="{DynamicResource Btn_Settings}" Click="Settings_Click" Padding="12,4" Margin="12,0,6,0"/>
                <ComboBox x:Name="LangBox" VerticalAlignment="Center" MinWidth="84"
                          SelectionChanged="LangBox_SelectionChanged">
                    <ComboBoxItem Content="中文" Tag="zh"/>
                    <ComboBoxItem Content="English" Tag="en"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText" Margin="8,4" Foreground="#666"/>
        </Border>

        <!-- Profile list -->
        <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  CanUserAddRows="False" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" RowHeight="26"
                  KeyboardNavigation.TabNavigation="Once"
                  GotKeyboardFocus="Grid_GotKeyboardFocus"
                  PreviewKeyDown="Grid_PreviewKeyDown"
                  MouseDoubleClick="Grid_MouseDoubleClick" Margin="0">
            <DataGrid.Resources>
                <!-- Vertically center the text that DataGridTextColumn generates in each cell. -->
                <Style TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.ColumnHeaderStyle>
                <!-- Column headers shouldn't be Tab stops (they added 7 extra stops). -->
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="IsTabStop" Value="False"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <!-- No per-cell editing, so hide the focus rectangle — but keep the cell
                         focusable so arrow-key row navigation still works. -->
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <!-- Replace the Fluent cell template so content fills the row and is
                         vertically centered, and drop the offset current-cell focus box. -->
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Background="{TemplateBinding Background}" Padding="6,0"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="ColName" Binding="{Binding Name}" Width="160"/>
                <DataGridTextColumn x:Name="ColGroup" Binding="{Binding Group}" Width="110"/>
                <DataGridTextColumn x:Name="ColHost" Binding="{Binding Host}" Width="160"/>
                <DataGridTextColumn x:Name="ColPort" Binding="{Binding Port}" Width="70"/>
                <DataGridTextColumn x:Name="ColUser" Binding="{Binding User}" Width="120"/>
                <DataGridTextColumn x:Name="ColAuth" Binding="{Binding AuthDisplay, Mode=OneWay}" Width="140"/>
                <DataGridTextColumn x:Name="ColNote" Binding="{Binding Note}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
