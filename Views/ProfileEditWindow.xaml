<Window x:Class="SSHProfileLauncher.Views.ProfileEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource EditTitle}" Height="430" Width="460"
        Icon="/Assets/app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontSize="13">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Lbl_Name}" Margin="0,6,10,6" VerticalAlignment="Center"/>
        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="NameBox" Margin="0,4" Padding="3"
                   TextChanged="NameBox_TextChanged"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Lbl_Host}" Margin="0,6,10,6" VerticalAlignment="Center"/>
        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="HostBox" Margin="0,4" Padding="3"
                   TextChanged="HostBox_TextChanged"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Lbl_Port}" Margin="0,6,10,6" VerticalAlignment="Center"/>
        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="PortBox" Margin="0,4" Padding="3" HorizontalAlignment="Left" Width="100"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource Lbl_User}" Margin="0,6,10,6" VerticalAlignment="Center"/>
        <TextBox   Grid.Row="3" Grid.Column="1" x:Name="UserBox" Margin="0,4" Padding="3"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource Lbl_Auth}" Margin="0,6,10,6" VerticalAlignment="Center"/>
        <ComboBox  Grid.Row="4" Grid.Column="1" x:Name="AuthBox" Margin="0,4" Padding="3"
                   SelectionChanged="AuthBox_SelectionChanged">
            <ComboBoxItem Content="{DynamicResource Auth_Password}" Tag="Password"/>
            <ComboBoxItem Content="{DynamicResource Auth_PublicKey}" Tag="PublicKey"/>
            <ComboBoxItem Content="{DynamicResource Auth_Kbdi}" Tag="KeyboardInteractive"/>
        </ComboBox>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource Lbl_KeyLoc}" Margin="0,6,10,6" VerticalAlignment="Center"
                   x:Name="KeyLabel"/>
        <DockPanel Grid.Row="5" Grid.Column="1" Margin="0,4" x:Name="KeyPanel">
            <TextBlock DockPanel.Dock="Right" Foreground="Gray" VerticalAlignment="Center" Margin="8,0,0,0"
                       Text="{DynamicResource KeyLoc_Hint}"/>
            <TextBox x:Name="KeyLocBox" Padding="3"/>
        </DockPanel>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource Lbl_Group}" Margin="0,6,10,6" VerticalAlignment="Center"/>
        <TextBox   Grid.Row="6" Grid.Column="1" x:Name="GroupBox" Margin="0,4" Padding="3"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="{DynamicResource Lbl_Note}" Margin="0,6,10,6" VerticalAlignment="Top"/>
        <TextBox   Grid.Row="7" Grid.Column="1" x:Name="NoteBox" Margin="0,4" Padding="3"
                   AcceptsReturn="True" TextWrapping="Wrap" Height="50" VerticalScrollBarVisibility="Auto"/>

        <Border Grid.Row="8" Grid.ColumnSpan="2" Margin="0,12,0,0" Padding="10"
                Background="#F4F6F8" CornerRadius="4" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="{DynamicResource Adv_Header}" FontWeight="SemiBold"/>
                <TextBlock x:Name="LinkedText" Foreground="Gray" Margin="0,4,0,6" TextWrapping="Wrap"
                           Text="{DynamicResource Adv_NotLinked}"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="{DynamicResource Btn_OpenInBitviseAdv}" Click="OpenInBitvise_Click" Padding="10,4" Margin="0,0,8,0"/>
                    <Button Content="{DynamicResource Btn_LinkTlp}" Click="LinkProfile_Click" Padding="10,4" Margin="0,0,8,0"/>
                    <Button Content="{DynamicResource Btn_Unlink}" Click="UnlinkProfile_Click" Padding="10,4" x:Name="UnlinkBtn"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="SaveConnectBtn" Content="{DynamicResource Btn_SaveConnect}" Click="SaveAndConnect_Click"
                    Padding="14,5" Margin="0,0,8,0" Visibility="Collapsed"/>
            <Button x:Name="SaveBtn" Content="{DynamicResource Btn_Save}" Click="Ok_Click" IsDefault="True" Padding="20,5" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource Btn_Cancel}" Click="Cancel_Click" IsCancel="True" Padding="20,5"/>
        </StackPanel>
    </Grid>
</Window>
