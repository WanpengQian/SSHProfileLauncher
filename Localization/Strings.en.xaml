<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- MainWindow toolbar / columns -->
    <sys:String x:Key="Btn_New">New</sys:String>
    <sys:String x:Key="Btn_Edit">Edit</sys:String>
    <sys:String x:Key="Btn_Delete">Delete</sys:String>
    <sys:String x:Key="Btn_Connect">Connect</sys:String>
    <sys:String x:Key="Btn_OpenInBitvise">Open in Bitvise</sys:String>
    <sys:String x:Key="Btn_Settings">Settings…</sys:String>
    <sys:String x:Key="Lbl_Search">Search:</sys:String>

    <sys:String x:Key="Col_Name">Name</sys:String>
    <sys:String x:Key="Col_Group">Group</sys:String>
    <sys:String x:Key="Col_Host">Host</sys:String>
    <sys:String x:Key="Col_Port">Port</sys:String>
    <sys:String x:Key="Col_User">User</sys:String>
    <sys:String x:Key="Col_Auth">Auth</sys:String>
    <sys:String x:Key="Col_Note">Note</sys:String>

    <!-- Status bar -->
    <sys:String x:Key="Status_Format">{0} profiles   |   BvSsh: {1}   |   Library: {2}</sys:String>
    <sys:String x:Key="Status_BvNotFound">not found (set it in Settings)</sys:String>

    <!-- MainWindow messages -->
    <sys:String x:Key="Msg_SelectFirst">Please select a profile first.</sys:String>
    <sys:String x:Key="Title_Info">Notice</sys:String>
    <sys:String x:Key="Confirm_Delete">Delete "{0}"?&#10;(The linked .tlp file itself is not deleted.)</sys:String>
    <sys:String x:Key="Title_ConfirmDelete">Confirm delete</sys:String>
    <sys:String x:Key="Msg_BvMissing">BvSsh.exe was not found. Please set the Bitvise SSH Client path in Settings first.</sys:String>
    <sys:String x:Key="Title_BvMissing">Bitvise missing</sys:String>
    <sys:String x:Key="Install_Prompt">Bitvise SSH Client was not detected.&#10;&#10;This app relies on it to make SSH connections. Please install it.&#10;&#10;Open the official Bitvise download page now?&#10;(If it is installed in a non-default location, click No and set BvSsh.exe in Settings.)</sys:String>
    <sys:String x:Key="Install_Title">Bitvise not found</sys:String>
    <sys:String x:Key="Title_CannotConnect">Cannot connect</sys:String>
    <sys:String x:Key="Title_CannotLaunchBitvise">Cannot launch Bitvise</sys:String>
    <sys:String x:Key="Title_CannotOpenBrowser">Cannot open browser</sys:String>
    <sys:String x:Key="Dlg_SelectBvSsh">Select BvSsh.exe</sys:String>
    <sys:String x:Key="Filter_BvSsh">BvSsh.exe|BvSsh.exe|Executables (*.exe)|*.exe</sys:String>

    <!-- ProfileEditWindow -->
    <sys:String x:Key="EditTitle">Edit Profile</sys:String>
    <sys:String x:Key="Lbl_Name">Name</sys:String>
    <sys:String x:Key="Lbl_Host">Host</sys:String>
    <sys:String x:Key="Lbl_Port">Port</sys:String>
    <sys:String x:Key="Lbl_User">Username</sys:String>
    <sys:String x:Key="Lbl_Auth">Auth method</sys:String>
    <sys:String x:Key="Lbl_KeyLoc">Key location</sys:String>
    <sys:String x:Key="Lbl_Group">Group</sys:String>
    <sys:String x:Key="Lbl_Note">Note</sys:String>
    <sys:String x:Key="Auth_Password">Password (prompt on connect)</sys:String>
    <sys:String x:Key="Auth_PublicKey">Public key</sys:String>
    <sys:String x:Key="Auth_Kbdi">Keyboard-interactive</sys:String>
    <sys:String x:Key="KeyLoc_Hint">a=any / g1=global key 1</sys:String>
    <sys:String x:Key="Adv_Header">Advanced (tunnels / port forwarding / host keys, etc.)</sys:String>
    <sys:String x:Key="Adv_NotLinked">No .tlp linked. Configure it in Bitvise, save as a profile, then click "Link .tlp…".</sys:String>
    <sys:String x:Key="Adv_Linked">Linked: {0}&#10;On connect this .tlp is used; fields other than Name are overridden by it.</sys:String>
    <sys:String x:Key="Btn_OpenInBitviseAdv">Open in Bitvise…</sys:String>
    <sys:String x:Key="Btn_LinkTlp">Link .tlp…</sys:String>
    <sys:String x:Key="Btn_Unlink">Unlink</sys:String>
    <sys:String x:Key="Btn_Save">Save</sys:String>
    <sys:String x:Key="Btn_Cancel">Cancel</sys:String>
    <sys:String x:Key="Msg_NeedName">Please enter a name.</sys:String>
    <sys:String x:Key="Msg_NeedHost">Please enter a host, or link a .tlp.</sys:String>
    <sys:String x:Key="Msg_PortRange">Port must be a number between 1 and 65535.</sys:String>
    <sys:String x:Key="Msg_OpenedInBitvise">Opened in Bitvise. After configuring advanced options, use "Save profile as…" in Bitvise to save a .tlp, then come back and click "Link .tlp…" to select it.</sys:String>
    <sys:String x:Key="Dlg_SelectProfile">Select Bitvise profile</sys:String>
    <sys:String x:Key="Filter_Profile">Bitvise profile (*.tlp;*.bscp)|*.tlp;*.bscp|All files (*.*)|*.*</sys:String>

    <!-- Username prompt -->
    <sys:String x:Key="Username_Title">Username required</sys:String>
    <sys:String x:Key="Username_Msg">This connection has no username. Enter the SSH username to log in with:</sys:String>
    <sys:String x:Key="Username_Remember">Remember in this profile</sys:String>
    <sys:String x:Key="Username_Empty">Please enter a username.</sys:String>
    <sys:String x:Key="Btn_Confirm">OK</sys:String>

    <!-- Misc -->
    <sys:String x:Key="Default_NewProfile">New connection</sys:String>

    <!-- Language switch -->
    <sys:String x:Key="Lang_Chinese">中文</sys:String>
    <sys:String x:Key="Lang_English">English</sys:String>
</ResourceDictionary>
